<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inequality Quest: Guardian of the Number Line</title>
    <!-- Tailwind CSS for high fidelity modern styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700;800&family=Noto+Sans+SC:wght=400;500;700;900&display=swap');
        body {
            font-family: 'Plus Jakarta Sans', 'Noto Sans SC', sans-serif;
            background: radial-gradient(circle at top, #1e1b4b, #0f172a);
        }
        .glow-button {
            transition: all 0.3s ease;
            box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
        }
        .glow-button:hover {
            box-shadow: 0 0 25px rgba(99, 102, 241, 0.8);
            transform: translateY(-2px);
        }
        .milestone-gem {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
    </style>
</head>
<body class="text-slate-100 min-h-screen flex flex-col justify-between overflow-x-hidden">

    <!-- Top Navigation Bar -->
    <header class="border-b border-indigo-900/50 bg-slate-900/80 backdrop-blur-md sticky top-0 z-50 px-6 py-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <div class="bg-gradient-to-tr from-indigo-500 to-purple-500 p-2.5 rounded-xl shadow-lg shadow-indigo-500/30">
                    <i class="fa-solid fa-compass-drafting text-xl text-white"></i>
                </div>
                <div>
                    <h1 class="font-extrabold text-lg tracking-tight bg-gradient-to-r from-indigo-200 via-purple-200 to-pink-300 bg-clip-text text-transparent">INEQUALITY QUEST</h1>
                    <p class="text-xs text-indigo-300 font-semibold tracking-wider uppercase">Misi Ketaksamaan Linear • 线性不等式任务</p>
                </div>
            </div>
            
            <!-- Dynamic Stats Bar -->
            <div id="game-stats" class="hidden flex items-center space-x-6">
                <!-- Score Indicator -->
                <div class="bg-slate-800/80 border border-slate-700/50 px-4 py-2 rounded-xl flex items-center space-x-2.5">
                    <i class="fa-solid fa-star text-amber-400 animate-pulse"></i>
                    <div>
                        <div class="text-[10px] text-slate-400 font-bold uppercase leading-none">Score / 得分</div>
                        <div id="player-score" class="text-base font-extrabold text-amber-300">0</div>
                    </div>
                </div>
                <!-- Health Indicator -->
                <div class="bg-slate-800/80 border border-slate-700/50 px-4 py-2 rounded-xl flex items-center space-x-2.5">
                    <i class="fa-solid fa-heart text-rose-500"></i>
                    <div>
                        <div class="text-[10px] text-slate-400 font-bold uppercase leading-none">Lives / 生命</div>
                        <div id="player-lives" class="text-base font-extrabold text-rose-400">❤️❤️❤️</div>
                    </div>
                </div>
            </div>

            <!-- Help Button -->
            <button onclick="toggleHelpModal()" class="text-slate-400 hover:text-white transition bg-slate-800/50 hover:bg-slate-800 p-2.5 rounded-lg border border-slate-700/30">
                <i class="fa-solid fa-circle-info text-lg"></i>
            </button>
        </div>
    </header>

    <!-- Main Game Window -->
    <main class="max-w-4xl w-full mx-auto p-4 flex-grow flex flex-col justify-center">
        
        <!-- ================= WELCOME SCREEN ================= -->
        <section id="screen-welcome" class="bg-slate-900/60 border border-slate-800/80 p-8 md:p-12 rounded-3xl backdrop-blur-xl shadow-2xl relative overflow-hidden my-6">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-purple-500/10 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl"></div>

            <div class="text-center space-y-6 relative z-10">
                <span class="px-4 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/30 text-xs font-bold text-indigo-300 uppercase tracking-widest">
                    Interactive Math Pilot • 数学互动课
                </span>
                <h2 class="text-4xl md:text-5xl font-black tracking-tight leading-none text-white">
                    Unlock the Secrets of <br>
                    <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Linear Inequalities</span>
                </h2>
                <h3 class="text-xl font-bold text-indigo-200">解开线性不等式的奥秘</h3>
                <p class="text-slate-300 max-w-xl mx-auto text-base">
                    Welcome, young Math wizard! Learn how to solve real-world problems, build graphs, and solve algebra equations using inequalities.
                    <br><span class="text-slate-400 text-sm mt-2 block">欢迎，年轻的数学勇士！通过解开现实谜题、绘制数轴并解决不等式方程来拯救数学维度。</span>
                </p>

                <!-- Language Selection Tip -->
                <div class="bg-slate-800/40 border border-slate-700/30 p-4 rounded-xl max-w-md mx-auto text-xs text-slate-300 flex items-center space-x-3 text-left">
                    <i class="fa-solid fa-language text-3xl text-indigo-400"></i>
                    <div>
                        <p class="font-bold">Trilingual Support (EN / 华语 / BM)</p>
                        <p class="text-slate-400">Questions are displayed in English with Mandarin and Bahasa Melayu translations to help you learn easier!</p>
                    </div>
                </div>

                <div class="pt-6">
                    <button onclick="startGame()" class="glow-button px-10 py-5 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-2xl font-bold text-lg text-white tracking-wide flex items-center space-x-3 mx-auto">
                        <span>Enter the Dimension (开始探索)</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </section>

        <!-- ================= MISSION SELECTOR ================= -->
        <section id="screen-mission-select" class="hidden space-y-8 my-6">
            <div class="text-center space-y-2">
                <h2 class="text-3xl font-extrabold text-white">Choose Your Mission / 选择任务</h2>
                <p class="text-slate-400">Complete all four stages to master Chapter 7. 完成四个关卡以掌握第七章。</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Mission 1 Card -->
                <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5 flex flex-col justify-between hover:border-indigo-500/50 transition duration-300 group relative">
                    <div class="space-y-3">
                        <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-500 group-hover:text-white transition duration-300">
                            <i class="fa-solid fa-tag"></i>
                        </div>
                        <div>
                            <h3 class="font-extrabold text-md text-white">Mission 1: The Decoder</h3>
                            <p class="text-[10px] text-indigo-300 font-bold mb-1">关卡 1：不等式翻译员</p>
                            <p class="text-xs text-slate-400">Translate real-life signs and limits into symbolic inequalities.</p>
                        </div>
                    </div>
                    <button onclick="startMission(1)" class="mt-4 w-full py-2.5 bg-slate-800 hover:bg-blue-600 text-white rounded-xl font-bold text-xs transition-all duration-300 flex items-center justify-center space-x-2">
                        <span>Start Mission 1 / 开始</span>
                        <i class="fa-solid fa-play"></i>
                    </button>
                </div>

                <!-- Mission 2 Card -->
                <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5 flex flex-col justify-between hover:border-purple-500/50 transition duration-300 group relative">
                    <div class="space-y-3">
                        <div class="w-10 h-10 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400 group-hover:bg-purple-500 group-hover:text-white transition duration-300">
                            <i class="fa-solid fa-chart-line"></i>
                        </div>
                        <div>
                            <h3 class="font-extrabold text-md text-white">Mission 2: Line Builder</h3>
                            <p class="text-[10px] text-indigo-300 font-bold mb-1">关卡 2：数轴绘制专家</p>
                            <p class="text-xs text-slate-400">Draw arrows and toggle open/solid boundary circles on the number line.</p>
                        </div>
                    </div>
                    <button id="btn-mission-2" onclick="startMission(2)" class="mt-4 w-full py-2.5 bg-slate-800 hover:bg-purple-600 text-white rounded-xl font-bold text-xs transition-all duration-300 flex items-center justify-center space-x-2">
                        <span>Start Mission 2 / 开始</span>
                        <i class="fa-solid fa-play"></i>
                    </button>
                </div>

                <!-- Mission 3 Card -->
                <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5 flex flex-col justify-between hover:border-pink-500/50 transition duration-300 group relative">
                    <div class="space-y-3">
                        <div class="w-10 h-10 rounded-xl bg-pink-500/10 border border-pink-500/20 flex items-center justify-center text-pink-400 group-hover:bg-pink-500 group-hover:text-white transition duration-300">
                            <i class="fa-solid fa-rotate"></i>
                        </div>
                        <div>
                            <h3 class="font-extrabold text-md text-white">Mission 3: Sign Flippers</h3>
                            <p class="text-[10px] text-indigo-300 font-bold mb-1">关卡 3：不等号大反转</p>
                            <p class="text-xs text-slate-400">Master algebraic steps! Beware of negative signs that flip inequality symbols.</p>
                        </div>
                    </div>
                    <button id="btn-mission-3" onclick="startMission(3)" class="mt-4 w-full py-2.5 bg-slate-800 hover:bg-pink-600 text-white rounded-xl font-bold text-xs transition-all duration-300 flex items-center justify-center space-x-2">
                        <span>Start Mission 3 / 开始</span>
                        <i class="fa-solid fa-play"></i>
                    </button>
                </div>

                <!-- Mission 4 Card -->
                <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5 flex flex-col justify-between hover:border-emerald-500/50 transition duration-300 group relative">
                    <div class="space-y-3">
                        <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 group-hover:bg-emerald-500 group-hover:text-white transition duration-300">
                            <i class="fa-solid fa-crosshairs"></i>
                        </div>
                        <div>
                            <h3 class="font-extrabold text-md text-white">Mission 4: Safe Zone</h3>
                            <p class="text-[10px] text-indigo-300 font-bold mb-1">关卡 4：避难安全区</p>
                            <p class="text-xs text-slate-400">Control a mascot in Cartesian coordinate plane and run into the rotating safe area!</p>
                        </div>
                    </div>
                    <button id="btn-mission-4" onclick="startMission(4)" class="mt-4 w-full py-2.5 bg-slate-800 hover:bg-emerald-600 text-white rounded-xl font-bold text-xs transition-all duration-300 flex items-center justify-center space-x-2">
                        <span>Start Mission 4 / 开始</span>
                        <i class="fa-solid fa-play"></i>
                    </button>
                </div>
            </div>

            <!-- Dashboard Teacher Helper / Instruction Note -->
            <div class="bg-slate-900/40 border border-slate-800 p-5 rounded-2xl">
                <h4 class="text-sm font-bold text-slate-300 mb-2 flex items-center space-x-2">
                    <i class="fa-solid fa-chalkboard-user text-indigo-400"></i>
                    <span>Teacher's Note / 教师指南:</span>
                </h4>
                <p class="text-xs text-slate-400 leading-relaxed">
                    This interactive tool helps students learn step-by-step. Let students use the top-right Info button (<i class="fa-solid fa-circle-info"></i>) to read rules of empty/solid circles and negative numbers anytime they get stuck.
                    <br><span class="text-indigo-300/80">提示：本系统包含完整的中文辅助说明，关卡 4 训练学生结合笛卡尔直角坐标系（Cartesian Coordinates）快速做出不等式区间位置的判断！你可以选择开启/关闭绿色安全区提示作为不同难度的挑战！</span>
                </p>
            </div>
        </section>

        <!-- ================= PLAY ZONE: MAIN INTERFACE ================= -->
        <section id="screen-gameplay" class="hidden flex flex-col space-y-6 my-6">
            
            <!-- Progress & Stage Info -->
            <div class="flex justify-between items-center bg-slate-900/50 border border-slate-800 px-5 py-3 rounded-2xl">
                <div>
                    <span id="gameplay-mission-title" class="text-xs font-bold uppercase text-indigo-400">Mission 1</span>
                    <h3 id="gameplay-question-num" class="text-lg font-bold text-white">Question 1 of 4</h3>
                </div>
                <div class="w-1/3 bg-slate-800 h-2.5 rounded-full overflow-hidden">
                    <div id="gameplay-progress-bar" class="bg-gradient-to-r from-indigo-500 to-purple-500 h-full transition-all duration-300" style="width: 25%"></div>
                </div>
            </div>

            <!-- Game Quest Sandbox -->
            <div class="bg-slate-900/60 border border-slate-800/80 rounded-3xl p-6 md:p-8 backdrop-blur-xl relative shadow-xl">
                
                <!-- Feedback Overlay Dialog -->
                <div id="feedback-overlay" class="hidden absolute inset-0 z-30 rounded-3xl backdrop-blur-md flex flex-col items-center justify-center p-6 text-center transition-all duration-300">
                    <div id="feedback-card" class="bg-slate-950/95 border-2 p-8 rounded-2xl max-w-md w-full shadow-2xl transform scale-95 transition-transform">
                        <div id="feedback-icon" class="w-16 h-16 rounded-full mx-auto flex items-center justify-center text-3xl mb-4"></div>
                        <h4 id="feedback-title" class="text-2xl font-black mb-2 text-white">Perfect!</h4>
                        <p id="feedback-desc" class="text-slate-300 text-sm mb-6"></p>
                        <div id="feedback-buttons-container" class="flex flex-col gap-2 w-full">
                            <button id="feedback-action-btn" class="w-full py-4 rounded-xl font-bold text-white transition-all duration-300 shadow-lg"></button>
                            <button id="feedback-pause-btn" class="hidden w-full py-2.5 rounded-xl font-bold bg-slate-800 hover:bg-slate-700 text-slate-300 transition-all border border-slate-700 text-xs flex items-center justify-center space-x-2">
                                <i class="fa-solid fa-pause"></i>
                                <span>Pause Auto-Advance / 暂停自动跳转</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- ================= MISSION 4 EXCLUSIVE MILESTONES ================= -->
                <div id="m4-milestone-panel" class="hidden bg-slate-950/40 border border-slate-800/60 p-4 rounded-2xl mb-6 flex flex-col sm:flex-row justify-between items-center gap-3">
                    <span class="text-xs font-extrabold text-emerald-400 tracking-wider uppercase flex items-center space-x-1.5">
                        <i class="fa-solid fa-flag-checkered animate-bounce"></i>
                        <span>Milestone Progress (通关进度):</span>
                    </span>
                    <div class="flex space-x-2" id="milestones-gems-container">
                        <!-- 8 Gems indicators will dynamically spawn here -->
                    </div>
                </div>

                <!-- QUESTION DISPLAY AREA -->
                <div id="question-text-area" class="space-y-4 mb-8 border-b border-slate-800 pb-6">
                    <!-- Dynamic badge indicating difficulty/topic -->
                    <span id="topic-badge" class="px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-md text-xs font-semibold text-indigo-300">
                        Topic Tag
                    </span>
                    
                    <!-- English Question -->
                    <h4 id="main-question-text" class="text-xl md:text-2xl font-extrabold text-white leading-snug">
                        Question description will load dynamically...
                    </h4>
                    
                    <!-- Chinese Question -->
                    <p id="chinese-translation-text" class="text-base font-semibold text-amber-300/95 leading-relaxed bg-amber-500/5 px-4 py-2.5 rounded-xl border border-amber-500/10">
                        中文翻译载入中...
                    </p>

                    <!-- Malay Question (KSSM reference) -->
                    <p id="malay-translation-text" class="text-xs italic text-slate-400 font-medium pl-1">
                        Terjemahan Bahasa Melayu...
                    </p>
                </div>

                <!-- ================= CORE INTERACTION PANELS ================= -->

                <!-- TYPE 1: MULTIPLE CHOICE (Mission 1 & Mission 3) -->
                <div id="panel-mcq" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- MCQ options are rendered here dynamically -->
                </div>

                <!-- TYPE 2: INTERACTIVE NUMBER LINE CONSTRUCTOR (Mission 2) -->
                <div id="panel-numberline" class="hidden space-y-8">
                    
                    <!-- SVG Interactive Number Line -->
                    <div class="bg-slate-950/80 border border-slate-800 p-6 rounded-2xl flex flex-col justify-center items-center select-none">
                        
                        <!-- Value selector status -->
                        <div class="text-sm font-semibold mb-4 text-indigo-200">
                            Selected Boundary Point / 选中端点: <span id="lbl-boundary" class="text-xl font-black text-amber-300">0</span>
                        </div>

                        <!-- SVG Graphic Canvas -->
                        <div class="w-full overflow-x-auto">
                            <svg id="svg-canvas" width="600" height="150" class="mx-auto min-w-[500px]">
                                <!-- Main Number Line Axis -->
                                <line x1="50" y1="90" x2="550" y2="90" stroke="#475569" stroke-width="4" stroke-linecap="round" />
                                <!-- Left arrow line -->
                                <path d="M 50 90 L 60 83 M 50 90 L 60 97" stroke="#475569" stroke-width="4" stroke-linecap="round" />
                                <!-- Right arrow line -->
                                <path d="M 550 90 L 540 83 M 550 90 L 540 97" stroke="#475569" stroke-width="4" stroke-linecap="round" />

                                <!-- Ticks and Labels dynamically generated -->
                                <g id="svg-ticks"></g>

                                <!-- The interactive user-constructed inequality graph -->
                                <g id="user-graph">
                                    <!-- Dynamic line constructed by the player -->
                                    <line id="user-line" x1="300" y1="50" x2="300" y2="50" stroke="#6366f1" stroke-width="5" stroke-dasharray="2" class="hidden" />
                                    <!-- Dynamic arrow head pointing left or right -->
                                    <path id="user-arrow" d="" fill="none" stroke="#6366f1" stroke-width="5" stroke-linecap="round" class="hidden" />
                                    <!-- Dynamic node circle representing open or closed -->
                                    <circle id="user-node" cx="300" cy="50" r="10" fill="#0f172a" stroke="#6366f1" stroke-width="4" class="hidden" />
                                </g>
                            </svg>
                        </div>
                        <p class="text-xs text-slate-500 mt-2"><i class="fa-solid fa-mouse-pointer mr-1"></i> Click any number above to set the anchor point. (点击下方数字来放置端点)</p>
                    </div>

                    <!-- Construction Controls Panel -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Circle Style Selector -->
                        <div class="bg-slate-800/40 border border-slate-700/30 p-5 rounded-2xl space-y-3">
                            <label class="block text-xs font-bold text-indigo-300 uppercase tracking-wider">Circle Style / 圆圈类型 (Jenis Titik)</label>
                            <div class="grid grid-cols-2 gap-3">
                                <button onclick="setCircleStyle('open')" id="btn-circle-open" class="py-3 px-4 rounded-xl border-2 border-indigo-500/20 hover:border-indigo-500 bg-slate-900/50 flex flex-col items-center justify-center transition">
                                    <div class="w-6 h-6 rounded-full border-2 border-slate-300 bg-transparent mb-1"></div>
                                    <span class="text-sm font-bold text-white">Open / 空心 (○)</span>
                                    <span class="text-[10px] text-slate-400">Strictly (<, >) 不含等号</span>
                                </button>
                                <button onclick="setCircleStyle('solid')" id="btn-circle-solid" class="py-3 px-4 rounded-xl border-2 border-indigo-500/20 hover:border-indigo-500 bg-slate-900/50 flex flex-col items-center justify-center transition">
                                    <div class="w-6 h-6 rounded-full bg-slate-300 mb-1"></div>
                                    <span class="text-sm font-bold text-white">Solid / 实心 (●)</span>
                                    <span class="text-[10px] text-slate-400">Equal allowed (≤, ≥) 包含等号</span>
                                </button>
                            </div>
                        </div>

                        <!-- Arrow Direction Selector -->
                        <div class="bg-slate-800/40 border border-slate-700/30 p-5 rounded-2xl space-y-3">
                            <label class="block text-xs font-bold text-indigo-300 uppercase tracking-wider">Arrow Direction / 箭头方向 (Arah)</label>
                            <div class="grid grid-cols-2 gap-3">
                                <button onclick="setDirection('left')" id="btn-dir-left" class="py-3 px-4 rounded-xl border-2 border-indigo-500/20 hover:border-indigo-500 bg-slate-900/50 flex flex-col items-center justify-center transition">
                                    <i class="fa-solid fa-arrow-left text-lg mb-1 text-slate-300"></i>
                                    <span class="text-sm font-bold text-white">Left / 向左 (←)</span>
                                    <span class="text-[10px] text-slate-400">Less than (<, ≤) 较小值</span>
                                </button>
                                <button onclick="setDirection('right')" id="btn-dir-right" class="py-3 px-4 rounded-xl border-2 border-indigo-500/20 hover:border-indigo-500 bg-slate-900/50 flex flex-col items-center justify-center transition">
                                    <i class="fa-solid fa-arrow-right text-lg mb-1 text-slate-300"></i>
                                    <span class="text-sm font-bold text-white">Right / 向右 (→)</span>
                                    <span class="text-[10px] text-slate-400">Greater than (>, ≥) 较大值</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Submit Interactive Graph Button -->
                    <div class="flex justify-center pt-4">
                        <button onclick="checkNumberlineAnswer()" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-xl font-bold text-white hover:opacity-90 shadow-lg shadow-emerald-500/20 transition flex items-center space-x-2">
                            <i class="fa-solid fa-circle-check"></i>
                            <span>Verify Graph / 确认解答 (Sahkan)</span>
                        </button>
                    </div>

                </div>

                <!-- TYPE 3: MISSION 4 CARTESIAN SAFEZONE REALTIME GAME -->
                <div id="panel-cartesian" class="hidden flex flex-col lg:flex-row gap-6 items-center">
                    
                    <!-- Cartesian Canvas Area -->
                    <div class="bg-slate-950 border-2 border-indigo-900/40 p-4 rounded-2xl relative select-none shadow-2xl">
                        <!-- Canvas -->
                        <canvas id="cartesian-canvas" width="400" height="400" class="bg-slate-950 rounded-xl max-w-full h-auto"></canvas>
                        
                        <!-- Top Real-time Countdown Timer Bar Overlay -->
                        <div class="absolute top-6 left-6 right-6">
                            <div class="flex justify-between items-center text-xs text-amber-300 font-extrabold mb-1 bg-slate-950/80 px-2 py-1 rounded">
                                <span class="uppercase tracking-wider">ACTIVE SAFEZONE COUNTDOWN</span>
                                <span id="lbl-countdown-timer">10.0s</span>
                            </div>
                            <div class="w-full bg-slate-900 h-2 rounded-full overflow-hidden border border-slate-800">
                                <div id="bar-countdown-timer" class="bg-gradient-to-r from-amber-400 to-rose-500 h-full transition-all duration-75" style="width: 100%"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Cartesian controls panel (D-pad & stats) -->
                    <div class="flex-grow w-full flex flex-col justify-between space-y-4">
                        
