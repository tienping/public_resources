        // --- MISSION 4 CARTESIAN SAFEZONE REALTIME LOGIC ---
        function startCartesianArenaRound(questionObj) {
            if (animFrameId) {
                cancelAnimationFrame(animFrameId);
            }
            
            // Set up rotating angles for the target clockwise motion
            m4Transition.startAngle = m4Transition.endAngle;
            
            // Calculate relative difference to force clockwise rotation
            let diff = (questionObj.targetAngle - (m4Transition.startAngle % 360) + 360) % 360;
            if (diff === 0 && questionObj.targetAngle !== (m4Transition.startAngle % 360)) {
                diff = 360;
            }
            m4Transition.endAngle = m4Transition.startAngle + diff;
            
            // Sync Hint Labels
            document.getElementById("lbl-safezone-hint").innerText = questionObj.safeDesc;
            updateMascotDisplay();

            // Set up real-time timer
            m4Timer.elapsed = 0;
            m4Timer.active = true;
            m4Timer.startTime = Date.now();

            // Trigger animation frame loop
            runCartesianLoop();
        }

        function runCartesianLoop() {
            if (gameState.currentMission !== 4 || !m4Timer.active) return;

            // Calculate exact elapsed seconds
            const now = Date.now();
            m4Timer.elapsed = (now - m4Timer.startTime) / 1000;
            
            let timeLeft = m4Timer.maxTime - m4Timer.elapsed;
            if (timeLeft <= 0) {
                timeLeft = 0;
                m4Timer.active = false;
                evaluateMascotInSafezone();
            }

            // Sync visual Timer bar and Label
            document.getElementById("lbl-countdown-timer").innerText = `${timeLeft.toFixed(1)}s`;
            const barPct = (timeLeft / m4Timer.maxTime) * 100;
            const timerBar = document.getElementById("bar-countdown-timer");
            timerBar.style.width = `${barPct}%`;
            
            // Update color based on urgency
            if (barPct < 30) {
                timerBar.className = "bg-rose-500 h-full transition-all duration-75";
            } else if (barPct < 60) {
                timerBar.className = "bg-amber-500 h-full transition-all duration-75";
            } else {
                timerBar.className = "bg-emerald-500 h-full transition-all duration-75";
            }

            // Rotate the safe zone starting at exactly 2 seconds remaining (t-2), and finishing at 1 second remaining
            let interpolationProgress = 0;
            if (timeLeft <= 1.0) {
                interpolationProgress = 1;
            } else if (timeLeft <= 2.0) {
                interpolationProgress = 2.0 - timeLeft;
            } else {
                interpolationProgress = 0;
            }
            m4Transition.currentAngle = m4Transition.startAngle + (m4Transition.endAngle - m4Transition.startAngle) * interpolationProgress;

            // Render Cartesian Frame onto Canvas
            drawCartesianArena();

            if (m4Timer.active) {
                animFrameId = requestAnimationFrame(runCartesianLoop);
            }
        }

        function drawCartesianArena() {
            if (!canvas || !ctx) return;

            // 1. Clear background
            ctx.fillStyle = "#020617";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // 2. Draw Grid coordinate helper lines
            ctx.lineWidth = 1;
            ctx.strokeStyle = "#1e293b";
            for (let i = -4; i <= 4; i++) {
                // Vertical grid helper
                let xPos = 200 + (i * 45);
                ctx.beginPath();
                ctx.moveTo(xPos, 0);
                ctx.lineTo(xPos, canvas.height);
                ctx.stroke();

                // Horizontal grid helper
                let yPos = 200 - (i * 45);
                ctx.beginPath();
                ctx.moveTo(0, yPos);
                ctx.lineTo(canvas.width, yPos);
                ctx.stroke();
            }

            // 3. Draw Axis Lines
            ctx.lineWidth = 2;
            ctx.strokeStyle = "#475569";
            // X-Axis
            ctx.beginPath();
            ctx.moveTo(10, 200);
            ctx.lineTo(390, 200);
            ctx.stroke();
            // Y-Axis
            ctx.beginPath();
            ctx.moveTo(200, 10);
            ctx.lineTo(200, 390);
            ctx.stroke();

            // Axis labels & arrows
            ctx.fillStyle = "#94a3b8";
            ctx.font = "bold 11px sans-serif";
            ctx.fillText("x", 385, 195);
            ctx.fillText("y", 205, 15);

            // 4. Draw tick numbers along axes
            ctx.fillStyle = "#475569";
            ctx.font = "9px sans-serif";
            for (let i = -4; i <= 4; i++) {
                if (i === 0) continue;
                let xPos = 200 + (i * 45);
                let yPos = 200 - (i * 45);

                // Tick marks
                ctx.fillRect(xPos - 1, 197, 2, 6);
                ctx.fillRect(197, yPos - 1, 6, 2);

                // Number labels
                ctx.fillText(i, xPos - 3, 215);
                ctx.fillText(i, 183, yPos + 3);
            }

            // 5. Draw the Dynamic Clockwise rotating Safe Zone overlay!
            // Visually show the green safe zone depending on the interactive toggle switch! (True/False setting)
            if (showCartesianHint) {
                ctx.save();
                ctx.translate(200, 200);
                ctx.rotate(m4Transition.currentAngle * Math.PI / 180);

                // Safe Zone colored block
                ctx.fillStyle = "rgba(16, 185, 129, 0.20)";
                ctx.strokeStyle = "rgba(16, 185, 129, 0.7)";
                ctx.lineWidth = 3;

                // Scaling offset coordinates based on boundary
                const currentQ = QUEST_DATABASE[4][gameState.currentQuestionIdx];
                let boundaryOffset = (currentQ ? currentQ.boundary : 0) * 45;

                ctx.beginPath();
                // We draw a large rectangle covering the active half-plane
                ctx.rect(boundaryOffset, -400, 800, 800);
                ctx.fill();

                // Safezone partition boundary line
                ctx.beginPath();
                ctx.moveTo(boundaryOffset, -400);
                ctx.lineTo(boundaryOffset, 400);
                ctx.stroke();
                ctx.restore();
            }

            // 6. Draw Mascot Player
            // Mapping Mascot grid coordinates to Canvas coordinates
            let canvasMascotX = 200 + (m4Mascot.x * 45);
            let canvasMascotY = 200 - (m4Mascot.y * 45); // Cartesian Y goes up, canvas goes down

            // Mascot Outer Radar Pulse Glow
            ctx.beginPath();
            ctx.arc(canvasMascotX, canvasMascotY, 14, 0, 2 * Math.PI);
            ctx.fillStyle = "rgba(99, 102, 241, 0.3)";
            ctx.fill();

            // Draw Mascot character emoji
            ctx.fillStyle = "#ffffff";
            ctx.font = "20px sans-serif";
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.fillText("🧙‍♂️", canvasMascotX, canvasMascotY);
        }

        function moveMascot(dx, dy) {
            if (gameState.currentMission !== 4 || !m4Timer.active) return;
            
            // Clamp coordinates to stay within the [-4, +4] Cartesian Grid
            m4Mascot.x = Math.max(-4, Math.min(4, m4Mascot.x + dx));
            m4Mascot.y = Math.max(-4, Math.min(4, m4Mascot.y + dy));
            
            updateMascotDisplay();
        }

        function updateMascotDisplay() {
            document.getElementById("lbl-mascot-x").innerText = m4Mascot.x;
            document.getElementById("lbl-mascot-y").innerText = m4Mascot.y;
        }

        function evaluateMascotInSafezone() {
            const currentQ = QUEST_DATABASE[4][gameState.currentQuestionIdx];
            const isInsideSafeZone = currentQ.evaluator(m4Mascot.x, m4Mascot.y);

            if (isInsideSafeZone) {
                gameState.score += 25;
                try { sfx.playSuccess(); } catch(e) {}
                
                // Reduce base countdown timer by 1 second for successfully solved questions
                m4Timer.maxTime = Math.max(3, m4Timer.maxTime - 1); 
                
                showFeedback(true, "Safe & Sound! / 安全抵挡！", `Excellent navigation! You've successfully landed in the safe coordinates representing: ${currentQ.safeDesc}.<br><span class="text-amber-300 font-bold text-xs">Note: Next round's countdown has been shortened to ${m4Timer.maxTime}s! Faster!</span>`);
            } else {
                gameState.lives = Math.max(0, gameState.lives - 1);
                try { sfx.playFailure(); } catch(e) {}
                
                showFeedback(false, "Caught in Hazard! / 置身危险区域！", `Oops! Your coordinates (${m4Mascot.x}, ${m4Mascot.y}) did not satisfy the safe zone inequality: ${currentQ.safeDesc}. Make sure you relocate before the timer finishes!`);
            }
            updateDashboardUI();
        }

        // --- TOGGLE CARTESIAN HINT REPRESENTATION (GREEN ZONE) ---
        function toggleCartesianHint() {
            showCartesianHint = !showCartesianHint;
            const btn = document.getElementById("btn-toggle-hint");
            
            if (showCartesianHint) {
                btn.innerText = "TRUE / 开启";
                btn.className = "px-5 py-1.5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl text-xs font-black transition-all duration-200 shadow-md";
            } else {
                btn.innerText = "FALSE / 关闭";
                btn.className = "px-5 py-1.5 bg-rose-600 hover:bg-rose-500 text-white rounded-xl text-xs font-black transition-all duration-200 shadow-md";
            }
            drawCartesianArena();
        }

        // --- KEY LISTENER ATTACHMENT FOR WASD CONTROLS ---
        window.addEventListener("keydown", function(e) {
            if (gameState.currentMission !== 4 || !m4Timer.active) return;
            
            const key = e.key.toLowerCase();
            if (key === "w" || e.key === "ArrowUp") {
                moveMascot(0, 1);
                e.preventDefault();
            } else if (key === "s" || e.key === "ArrowDown") {
                moveMascot(0, -1);
                e.preventDefault();
            } else if (key === "a" || e.key === "ArrowLeft") {
                moveMascot(-1, 0);
                e.preventDefault();
            } else if (key === "d" || e.key === "ArrowRight") {
                moveMascot(1, 0);
                e.preventDefault();
            }
        });

        // --- FEEDBACK WINDOW CONTROL ---
        function showFeedback(isCorrect, title, desc) {
            // Pause countdown activity during feedback
            m4Timer.active = false;
            
            // Clear any lingering feedback auto-advance timers first
            if (feedbackTimer) {
                clearInterval(feedbackTimer);
                feedbackTimer = null;
            }

            const overlay = document.getElementById("feedback-overlay");
            const card = document.getElementById("feedback-card");
            const icon = document.getElementById("feedback-icon");
            const titleEl = document.getElementById("feedback-title");
            const descEl = document.getElementById("feedback-desc");
            const actBtn = document.getElementById("feedback-action-btn");
            const pauseBtn = document.getElementById("feedback-pause-btn");

            pauseBtn.classList.add("hidden"); // Default hidden

            // Setup styling depending on correct state
            if (isCorrect) {
                card.className = "bg-slate-900 border-2 border-emerald-500/80 p-8 rounded-2xl max-w-md w-full shadow-2xl transition transform scale-100";
                icon.className = "w-16 h-16 rounded-full mx-auto flex items-center justify-center text-3xl mb-4 bg-emerald-500/10 text-emerald-400";
                icon.innerHTML = `<i class="fa-solid fa-award"></i>`;
                titleEl.className = "text-2xl font-black mb-2 text-emerald-400";
                
                actBtn.className = "w-full py-4 rounded-xl font-bold text-white transition-all bg-emerald-600 hover:bg-emerald-500 shadow-lg shadow-emerald-600/20";
                actBtn.innerText = "Continue / 下一题";
                actBtn.onclick = () => {
                    if (feedbackTimer) {
                        clearInterval(feedbackTimer);
                        feedbackTimer = null;
                    }
                    advanceQuest();
                };

                // AUTO-ADVANCE SETUP EXCLUSIVE TO MISSION 4
                if (gameState.currentMission === 4) {
                    pauseBtn.classList.remove("hidden");
                    let secondsLeft = 2;
                    actBtn.innerText = `Continue / 下一题 (${secondsLeft}s)`;
                    
                    // Pause Button Event Listener
                    pauseBtn.onclick = () => {
                        if (feedbackTimer) {
                            clearInterval(feedbackTimer);
                            feedbackTimer = null;
                        }
                        pauseBtn.classList.add("hidden");
                        actBtn.innerText = "Continue / 下一题";
                    };

                    feedbackTimer = setInterval(() => {
                        secondsLeft--;
                        if (secondsLeft <= 0) {
                            clearInterval(feedbackTimer);
                            feedbackTimer = null;
                            advanceQuest();
                        } else {
                            actBtn.innerText = `Continue / 下一题 (${secondsLeft}s)`;
                        }
                    }, 1000);
                }
            } else {
                card.className = "bg-slate-900 border-2 border-rose-500/80 p-8 rounded-2xl max-w-md w-full shadow-2xl transition transform scale-100";
                icon.className = "w-16 h-16 rounded-full mx-auto flex items-center justify-center text-3xl mb-4 bg-rose-500/10 text-rose-400";
                icon.innerHTML = `<i class="fa-solid fa-circle-exclamation"></i>`;
                titleEl.className = "text-2xl font-black mb-2 text-rose-400";
                
                if (gameState.lives <= 0) {
                    actBtn.className = "w-full py-4 rounded-xl font-bold text-white transition-all bg-rose-600 hover:bg-rose-500 shadow-lg shadow-rose-600/20";
                    actBtn.innerText = "Try Game Again / 重新开始挑战";
                    actBtn.onclick = () => returnToMainOnFail();
                } else {
                    actBtn.className = "w-full py-4 rounded-xl font-bold text-white transition-all bg-slate-800 hover:bg-slate-700 border border-slate-700";
                    actBtn.innerText = "Retry / 重新作答";
                    actBtn.onclick = () => loadQuestion();
                }
            }

            titleEl.innerText = title;
            descEl.innerHTML = desc;
            overlay.classList.remove("hidden");
        }

        function advanceQuest() {
            // Prevent timer memory leak
            if (feedbackTimer) {
                clearInterval(feedbackTimer);
                feedbackTimer = null;
            }

            const questions = QUEST_DATABASE[gameState.currentMission];
            
            if (gameState.currentQuestionIdx + 1 < questions.length) {
                gameState.currentQuestionIdx++;
                loadQuestion();
            } else {
                // Completed the final question of the current mission
                gameState.completedMissions.add(gameState.currentMission);
                try { sfx.playComplete(); } catch(e) {}

                // If finished all missions, display victory
                if (gameState.completedMissions.size >= 4) {
                    goToVictoryScreen();
                } else {
                    // Go back to mission hub with accomplishments saved
                    document.getElementById("screen-gameplay").classList.add("hidden");
                    document.getElementById("screen-mission-select").classList.remove("hidden");
                    updateDashboardUI();
                }
            }
        }

        function returnToMainOnFail() {
            if (feedbackTimer) {
                clearInterval(feedbackTimer);
                feedbackTimer = null;
            }
            document.getElementById("screen-gameplay").classList.add("hidden");
            document.getElementById("screen-mission-select").classList.remove("hidden");
            resetGameSession();
        }

        function abandonMission() {
            m4Timer.active = false;
            if (animFrameId) {
                cancelAnimationFrame(animFrameId);
            }
            if (feedbackTimer) {
                clearInterval(feedbackTimer);
                feedbackTimer = null;
            }
            document.getElementById("screen-gameplay").classList.add("hidden");
            document.getElementById("screen-mission-select").classList.remove("hidden");
            updateDashboardUI();
        }

        function goToMissionSelect() {
            if (feedbackTimer) {
                clearInterval(feedbackTimer);
                feedbackTimer = null;
            }
            document.getElementById("screen-victory").classList.add("hidden");
            document.getElementById("screen-mission-select").classList.remove("hidden");
            resetGameSession();
        }

        function goToVictoryScreen() {
            if (feedbackTimer) {
                clearInterval(feedbackTimer);
                feedbackTimer = null;
            }
            document.getElementById("screen-gameplay").classList.add("hidden");
            document.getElementById("screen-victory").classList.remove("hidden");
            document.getElementById("recap-score").innerText = gameState.score;
            
            // Assign creative ranking system badge
            const rankEl = document.getElementById("recap-rank");
            if (gameState.score >= 500) {
                rankEl.innerText = "Grandmaster of the Number Line 👑";
                rankEl.className = "text-md font-extrabold text-amber-300";
            } else if (gameState.score >= 300) {
                rankEl.innerText = "Inequality Specialist ⚡";
                rankEl.className = "text-md font-extrabold text-purple-300";
            } else {
                rankEl.innerText = "Guardian Apprentice 🌱";
                rankEl.className = "text-md font-extrabold text-indigo-300";
            }
        }

        // Help Modal Controls
        function toggleHelpModal() {
            const modal = document.getElementById("help-modal");
            modal.classList.toggle("hidden");
        }
    </script>
